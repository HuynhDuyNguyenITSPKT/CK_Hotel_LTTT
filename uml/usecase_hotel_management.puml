@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam ranksep 80
skinparam nodesep 40
skinparam shadowing false

actor "Quản trị viên" as Admin
actor "Quản lý" as Manager
actor "Lễ tân" as Receptionist

rectangle "Hệ thống Quản lý Khách sạn" {
  package "Truy cập hệ thống" {
    usecase "Đăng nhập" as UC_Login
    usecase "Đăng xuất" as UC_Logout
    usecase "Xem bảng điều khiển" as UC_ViewDashboard
    usecase "Tìm kiếm và lọc dữ liệu" as UC_SearchFilter
  }

  package "Quản trị hệ thống" {
    usecase "Quản lý tài khoản" as UC_ManageAccounts
    usecase "Quản lý nhân viên" as UC_ManageEmployees
    usecase "Tạo nhân viên và tài khoản" as UC_CreateEmployeeAccount
    usecase "Quản lý phòng" as UC_ManageRooms
    usecase "Quản lý loại phòng" as UC_ManageRoomTypes
    usecase "Quản lý danh mục dịch vụ" as UC_ManageServiceCatalog
    usecase "Quản lý danh mục khuyến mãi" as UC_ManagePromotionCatalog
    usecase "Quản lý khách hàng" as UC_ManageCustomers
    usecase "Xem báo cáo" as UC_ViewReports
    usecase "Xuất báo cáo" as UC_ExportReports
  }

  package "Nghiệp vụ quản lý" {
    usecase "Cập nhật phòng (Quản lý)" as UC_ManagerUpdateRooms
    usecase "Cập nhật khuyến mãi (Quản lý)" as UC_ManagerUpdatePromotions
    usecase "Cập nhật dịch vụ (Quản lý)" as UC_ManagerUpdateServices
  }

  package "Nghiệp vụ lễ tân" {
    usecase "Tra cứu khách theo SĐT" as UC_LookupCustomerByPhone
    usecase "Tạo đặt phòng" as UC_CreateBooking
    usecase "Hủy đặt phòng" as UC_CancelBooking
    usecase "Check-in đặt phòng" as UC_CheckInBooking
    usecase "Check-out đặt phòng" as UC_CheckOutBooking
    usecase "Thêm sử dụng dịch vụ" as UC_AddServiceUsage
    usecase "Xóa sử dụng dịch vụ" as UC_RemoveServiceUsage
    usecase "Áp dụng khuyến mãi" as UC_ApplyPromotion
    usecase "Thực hiện thanh toán" as UC_ProcessPayment
    usecase "Áp dụng KM và thanh toán" as UC_ApplyPromotionAndPayment
    usecase "Cập nhật trạng thái phòng" as UC_UpdateRoomStatus
  }

  package "Kiểm tra nghiệp vụ" {
    usecase "Kiểm tra dữ liệu đặt phòng" as UC_ValidateBookingData
    usecase "Kiểm tra phòng trống" as UC_CheckRoomAvailability
    usecase "Kiểm tra điều kiện check-in" as UC_ValidateCheckInConditions
    usecase "Kiểm tra điều kiện check-out" as UC_ValidateCheckOutConditions
    usecase "Kiểm tra công nợ còn lại" as UC_ValidateOutstandingDebt
    usecase "Cập nhật tổng tiền hóa đơn" as UC_UpdateInvoiceTotal
  }
}

' Force horizontal spread between module groups
UC_ViewDashboard -[hidden]right-> UC_ManageAccounts
UC_ManageAccounts -[hidden]right-> UC_ManagerUpdateRooms
UC_ManagerUpdateRooms -[hidden]right-> UC_LookupCustomerByPhone
UC_LookupCustomerByPhone -[hidden]right-> UC_ValidateBookingData

Admin --> UC_Login
Admin --> UC_Logout
Admin --> UC_ViewDashboard
Admin --> UC_SearchFilter

Manager --> UC_Login
Manager --> UC_Logout
Manager --> UC_ViewDashboard
Manager --> UC_SearchFilter

Receptionist -left-> UC_Login
Receptionist -left-> UC_Logout
Receptionist -left-> UC_ViewDashboard
Receptionist -left-> UC_SearchFilter

Admin --> UC_ManageAccounts
Admin --> UC_ManageEmployees
Admin --> UC_ManageRooms
Admin --> UC_ManageRoomTypes
Admin --> UC_ManageServiceCatalog
Admin --> UC_ManagePromotionCatalog
Admin --> UC_ManageCustomers
Admin --> UC_ViewReports
Admin --> UC_ExportReports

Manager --> UC_ViewReports
Manager --> UC_ExportReports
Manager --> UC_ManagerUpdateRooms
Manager --> UC_ManagerUpdatePromotions
Manager --> UC_ManagerUpdateServices

Receptionist -left-> UC_LookupCustomerByPhone
Receptionist -left-> UC_CreateBooking
Receptionist -left-> UC_CancelBooking
Receptionist -left-> UC_CheckInBooking
Receptionist -left-> UC_CheckOutBooking
Receptionist -left-> UC_AddServiceUsage
Receptionist -left-> UC_RemoveServiceUsage
Receptionist -left-> UC_ApplyPromotion
Receptionist -left-> UC_ProcessPayment
Receptionist -left-> UC_ApplyPromotionAndPayment
Receptionist -left-> UC_UpdateRoomStatus

UC_ViewReports .> UC_SearchFilter : <<include>>
UC_ExportReports .> UC_ViewReports : <<extend>>

UC_ManageEmployees .> UC_CreateEmployeeAccount : <<include>>

UC_CreateBooking .> UC_LookupCustomerByPhone : <<include>>
UC_CreateBooking .> UC_ValidateBookingData : <<include>>
UC_CreateBooking .> UC_CheckRoomAvailability : <<include>>

UC_CheckInBooking .> UC_ValidateCheckInConditions : <<include>>
UC_CheckOutBooking .> UC_ValidateCheckOutConditions : <<include>>
UC_CheckOutBooking .> UC_ValidateOutstandingDebt : <<include>>

UC_AddServiceUsage .> UC_UpdateInvoiceTotal : <<include>>
UC_RemoveServiceUsage .> UC_UpdateInvoiceTotal : <<include>>
UC_ApplyPromotion .> UC_UpdateInvoiceTotal : <<include>>
UC_ProcessPayment .> UC_ValidateOutstandingDebt : <<include>>

UC_ApplyPromotionAndPayment .> UC_ApplyPromotion : <<include>>
UC_ApplyPromotionAndPayment .> UC_ProcessPayment : <<include>>

@enduml
