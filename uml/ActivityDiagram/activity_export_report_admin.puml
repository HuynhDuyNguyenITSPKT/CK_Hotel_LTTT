@startuml
start
:Admin requests report export;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  if (Report type?) then (Invoices)
    if (Format?) then (Excel)
      :Call exportInvoicesExcel(day, month, year);
      :Return xlsx file response;
    else (PDF)
      :Call exportInvoicesPdf(day, month, year);
      :Return pdf file response;
    endif
  else (Payments)
    if (Format?) then (Excel)
      :Call exportPaymentsExcel(day, month, year);
      :Return xlsx file response;
    else (PDF)
      :Call exportPaymentsPdf(day, month, year);
      :Return pdf file response;
    endif
  endif
else (No)
  :Return HTTP 302 Location /login;
endif

stop
@enduml
