@startuml
start
:Admin submits /admin/employees/{employeeId}/role;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  :Call updateEmployeeRole(employeeId, role);
  if (Service throws IllegalArgumentException?) then (Yes)
    :Set flash error;
  else (No)
    :Set flash success;
  endif
  :Redirect /admin/dashboard?tab=employees;
else (No)
  :Redirect /login;
endif

stop
@enduml
