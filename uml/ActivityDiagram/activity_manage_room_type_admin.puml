@startuml
start
:Admin submits room-type action;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  if (Action?) then (Create)
    :Call createRoomType(request, imageFile);
  elseif (Update)
    :Call updateRoomType(roomTypeId, request, imageFile);
  else (Delete)
    :Call deleteRoomType(roomTypeId);
  endif

  if (IllegalArgumentException?) then (Yes)
    :Set flash error from service;
  elseif (Upload/other Exception?)
    :Set flash cloudinary error;
  else (No)
    :Set flash success;
  endif

  :Redirect /admin/dashboard?tab=room-types;
else (No)
  :Redirect /login;
endif

stop
@enduml
