@startuml
start
:Admin submits promotion action;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  if (Action?) then (Create)
    :Call createPromotion(request);
  elseif (Update)
    :Call updatePromotion(promotionId, request);
  else (Delete)
    :Call deletePromotion(promotionId);
  endif

  if (Service throws IllegalArgumentException?) then (Yes)
    :Set flash error;
  else (No)
    :Set flash success;
  endif

  :Redirect /admin/dashboard?tab=promotions;
else (No)
  :Redirect /login;
endif

stop
@enduml
