@startuml
start
:Admin submits room action;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  if (Action?) then (Create)
    :Call createRoom(request, imageFile);
  elseif (Update)
    :Call updateRoom(roomId, request, imageFile);
  else (Delete)
    :Call deleteRoom(roomId);
  endif

  if (IllegalArgumentException?) then (Yes)
    :Set flash error from service;
  elseif (Upload/other Exception?)
    :Set flash cloudinary error;
  else (No)
    :Set flash success;
  endif

  :Redirect /admin/dashboard?tab=rooms;
else (No)
  :Redirect /login;
endif

stop
@enduml
