@startuml
start
:Admin submits service action;
:Authorize with requireAdmin(session);

if (Authorized?) then (Yes)
  if (Action?) then (Create)
    :Call createService(request, imageFile);
  elseif (Update)
    :Call updateService(serviceId, request, imageFile);
  else (Delete)
    :Call deleteService(serviceId);
  endif

  if (IllegalArgumentException?) then (Yes)
    :Set flash error from service;
  elseif (Upload/other Exception?)
    :Set flash cloudinary error;
  else (No)
    :Set flash success;
  endif

  :Redirect /admin/dashboard?tab=services;
else (No)
  :Redirect /login;
endif

stop
@enduml
