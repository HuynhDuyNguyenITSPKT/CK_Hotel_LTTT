@startuml
left to right direction
skinparam actorStyle awesome

actor Staff
actor Admin
Admin --|> Staff

rectangle "Library Management System" {
  usecase "Login" as UC1
  usecase "View Dashboard" as UC2
  usecase "Manage Books" as UC3
  usecase "Manage Readers" as UC4
  usecase "Create Loan" as UC5
  usecase "Return Book" as UC6
  usecase "Search Loan" as UC7
  usecase "View Statistics" as UC8
  usecase "Logout" as UC9
  usecase "Check Available Quantity" as UC10
  usecase "Update Book Stock" as UC11
}

Staff --> UC1
Staff --> UC2
Staff --> UC3
Staff --> UC4
Staff --> UC5
Staff --> UC6
Staff --> UC7
Staff --> UC9

Admin --> UC8

UC5 .> UC10 : <<include>>
UC5 .> UC11 : <<include>>
UC6 .> UC11 : <<include>>

@enduml
