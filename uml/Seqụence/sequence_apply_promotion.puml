@startuml
actor Receptionist
participant "InvoicePaymentPanel" as View
participant "ReceptionistThanhToanController" as Controller
participant "ReceptionistAuthorizationSupport" as Auth
participant "ThanhToanService" as Service
participant "DatPhongRepository" as DatPhongRepo
participant "ChiTietDatPhongRepository" as ChiTietRepo
participant "KhuyenMaiRepository" as KhuyenMaiRepo
participant "HoaDonRepository" as HoaDonRepo
participant "SuDungDichVuRepository" as SuDungRepo
database "MySQL / JPA" as DB

Receptionist -> View : Enter promotion code (optional)
Receptionist -> View : Click Apply Promotion
View -> Controller : apDungKhuyenMai(datPhongId, maKhuyenMai)
Controller -> Auth : requireReceptionist(session)

alt Authorized
  Controller -> Service : apDungMaKhuyenMai(datPhongId, maKhuyenMai, employeeId)
  Service -> DatPhongRepo : findById(datPhongId)
  DatPhongRepo -> DB : SELECT dat_phong
  DB --> DatPhongRepo : DatPhong

  Service -> ChiTietRepo : findByDatPhongIdOrderByIdDesc(datPhongId)
  ChiTietRepo -> DB : SELECT chi_tiet_dat_phong
  DB --> ChiTietRepo : booking details

  Service -> SuDungRepo : tinhTongTienTheoDatPhongId(datPhongId)
  SuDungRepo -> DB : SELECT SUM(service_total)
  DB --> SuDungRepo : totalService

  Service -> HoaDonRepo : saveOrUpdateHoaDon(...)
  HoaDonRepo -> DB : INSERT/UPDATE hoa_don
  DB --> HoaDonRepo : HoaDon

  alt maKhuyenMai is blank
    Service -> HoaDonRepo : save(clear promotions)
    HoaDonRepo -> DB : UPDATE hoa_don
    DB --> HoaDonRepo : saved
  else maKhuyenMai provided
    Service -> KhuyenMaiRepo : findAllByOrderByIdDesc()
    KhuyenMaiRepo -> DB : SELECT khuyen_mai
    DB --> KhuyenMaiRepo : promotion list

    Service -> HoaDonRepo : existsKhuyenMaiDaDungBoiSdt(sdt, kmId, datPhongId)
    HoaDonRepo -> DB : SELECT promotion usage by customer phone
    DB --> HoaDonRepo : used / not used

    alt Promotion not used before
      Service -> HoaDonRepo : save(set promotion)
      HoaDonRepo -> DB : UPDATE hoa_don
      DB --> HoaDonRepo : saved
    else Promotion already used
      Service --> Controller : throw error
      Controller --> View : error message
      View --> Receptionist : Show cannot reuse code
    end
  end

  Service -> HoaDonRepo : save(recalculate total)
  HoaDonRepo -> DB : UPDATE hoa_don
  DB --> HoaDonRepo : updated total

  Service --> Controller : success
  Controller --> View : success message
  View --> Receptionist : Show promotion applied
else Unauthorized
  Controller --> View : redirect:/login
  View --> Receptionist : Session expired
end
@enduml
