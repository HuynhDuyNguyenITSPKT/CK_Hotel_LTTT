@startuml
actor Admin
participant "AdminRoomController" as Controller
participant "AdminAuthorizationSupport" as Auth
participant "IQuanTriTongHopService" as Service
participant "RedirectAttributes" as Flash
participant "HttpSession" as Session

Admin -> Controller : POST /admin/rooms
Controller -> Auth : requireAdmin(session)
Auth -> Session : getAttribute(CURRENT_USER)
Session --> Auth : LoginSession/null
Auth --> Controller : LoginSession/null

alt Unauthorized
  Controller --> Admin : redirect:/login
else Authorized
  Controller -> Service : createRoom(request, imageFile)
  alt IllegalArgumentException
    Service --> Controller : throw
    Controller -> Flash : add error
  else Upload/other Exception
    Service --> Controller : throw
    Controller -> Flash : add cloudinary error
  else Success
    Service --> Controller : ok
    Controller -> Flash : add success
  end
  Controller --> Admin : redirect:/admin/dashboard?tab=rooms
end
@enduml
