@startuml
actor Manager
participant "ManagerDashboardController" as Controller
participant "IBaoCaoQuanLyService" as ReportService
participant "HttpSession" as Session

Manager -> Controller : GET /manager/reports/... (excel/pdf)
Controller -> Session : check isManager(session)
Session --> Controller : true/false

alt Unauthorized
  Controller --> Manager : HTTP 302 Location /login
else Authorized
  alt Invoices Excel
    Controller -> ReportService : xuatBaoCaoHoaDonExcel(day, month, year)
    ReportService --> Controller : byte[]
    Controller --> Manager : file xlsx
  else Invoices PDF
    Controller -> ReportService : xuatBaoCaoHoaDonPdf(day, month, year)
    ReportService --> Controller : byte[]
    Controller --> Manager : file pdf
  else Payments Excel
    Controller -> ReportService : xuatBaoCaoThanhToanExcel(day, month, year)
    ReportService --> Controller : byte[]
    Controller --> Manager : file xlsx
  else Payments PDF
    Controller -> ReportService : xuatBaoCaoThanhToanPdf(day, month, year)
    ReportService --> Controller : byte[]
    Controller --> Manager : file pdf
  end
end
@enduml
