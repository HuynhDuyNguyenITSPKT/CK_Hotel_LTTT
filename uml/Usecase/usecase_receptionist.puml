@startuml
' --- Configuration ---
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam ranksep 100
skinparam nodesep 20
skinparam shadowing false

actor "Receptionist" as Receptionist

rectangle "Hotel Management System" {

  package "System Access" {
    usecase "Login" as UC_Login
    usecase "Logout" as UC_Logout
    usecase "View Dashboard" as UC_ViewDashboard
    usecase "Search & Filter Data" as UC_SearchFilter
  }

  package "Reception Operations" {
    usecase "Lookup Customer by Phone" as UC_LookupCustomerByPhone
    usecase "Create Booking" as UC_CreateBooking
    usecase "Cancel Booking" as UC_CancelBooking
    usecase "Check-in" as UC_CheckIn
    usecase "Check-out" as UC_CheckOut
    usecase "Add Service Usage" as UC_AddServiceUsage
    usecase "Remove Service Usage" as UC_RemoveServiceUsage
    usecase "Apply Promotion" as UC_ApplyPromotion
    usecase "Process Payment" as UC_ProcessPayment
    usecase "Apply Promo & Payment" as UC_ApplyPromoPayment
    usecase "Update Room Status" as UC_UpdateRoomStatus
  }
}

' --- Connections ---
Receptionist --> UC_Login
Receptionist --> UC_Logout
Receptionist --> UC_ViewDashboard
Receptionist --> UC_SearchFilter

Receptionist --> UC_LookupCustomerByPhone
Receptionist --> UC_CreateBooking
Receptionist --> UC_CancelBooking
Receptionist --> UC_CheckIn
Receptionist --> UC_CheckOut
Receptionist --> UC_AddServiceUsage
Receptionist --> UC_RemoveServiceUsage
Receptionist --> UC_ApplyPromotion
Receptionist --> UC_ProcessPayment
Receptionist --> UC_ApplyPromoPayment
Receptionist --> UC_UpdateRoomStatus

' --- Relationships (Includes) ---
UC_CreateBooking ..> UC_LookupCustomerByPhone : <<include>>
UC_ApplyPromoPayment ..> UC_ApplyPromotion : <<include>>
UC_ApplyPromoPayment ..> UC_ProcessPayment : <<include>>

@enduml
